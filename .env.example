# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
# NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Telegram Bot API token — get from @BotFather
TELEGRAM_BOT_TOKEN=

# API key from https://vertex-key.com
VERTEX_KEY_API_KEY=

# Path to your Google Service Account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# ── AI (optional) ─────────────────────────────────────────────
# API base URL (default: https://vertex-key.com/api/v1)
VERTEX_KEY_BASE_URL=https://vertex-key.com/api/v1
# Chat model ID (default: aws/claude-sonnet-4-6)
AI_CHAT_MODEL=aws/claude-sonnet-4-6
# Fast model ID (default: aws/claude-haiku-4-5)
AI_FAST_MODEL=aws/claude-haiku-4-5

# ── Google (optional) ─────────────────────────────────────────
# Default Google Doc ID for saving content
GOOGLE_DOC_ID=
# Drive folder ID for photo uploads
GOOGLE_DRIVE_FOLDER_ID=

# ── LemonSqueezy payments (optional — enables /upgrade) ───────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_PREMIUM_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Port for the webhook Express server (default: 3000)
WEBHOOK_PORT=3000

# ── Admin (optional) ──────────────────────────────────────────
# Telegram user IDs treated as admins (always Premium access).
# Comma-separated, e.g. ADMIN_USER_IDS=123456789,987654321
ADMIN_USER_IDS=
